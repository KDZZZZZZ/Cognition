# Environment Configuration

# API Keys (Required for AI features)
MOONSHOT_API_KEY=sk-your-kimi-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
DEFAULT_MODEL=kimi-latest

# Optional provider fallbacks
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_VL_EMBEDDING_MODEL=qwen3-vl-embedding
QWEN_VL_EMBEDDING_DIM=2048
SEGMENT_VECTOR_DOCUMENT_MAX_CHARS=2400
QWEN_DOC_FALLBACK_ENABLED=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/knowledge_ide

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600

# Vector Store
CHROMA_PERSIST_DIR=chroma_db

# Visual Retrieval (Multimodal Long PDF Reading)
VISUAL_RETRIEVAL_ENABLED=true
VISUAL_RETRIEVAL_MODEL=kimi-k2.5
VISUAL_RETRIEVAL_MAX_PAGES_PER_FILE=120
VISUAL_RETRIEVAL_TOP_K=4
VISUAL_RETRIEVAL_CANDIDATES=20
VISUAL_RETRIEVAL_VISION_RERANK_CANDIDATES=8
VISUAL_DEEP_READ_PAGE_WINDOW=1
VISUAL_DEEP_READ_MAX_CHARS=3500
VISUAL_PAGE_IMAGE_DPI=110
VISUAL_PAGE_IMAGE_MAX_EDGE=960
VISUAL_PAGE_IMAGE_QUALITY=72

# CORS (Add your frontend URLs)
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]
